    {
      "type": "text", "id": "flow2-note", "x": 30, "y": 510, "width": 800, "height": 55,
      "text": "Watermark: cada lado guarda el último sequence_number procesado.\nAl reconectar, el sync resume desde el watermark (no retransmite todo).\nIdempotencia garantizada por ULID/UUID como primary key (UPSERT = INSERT ON CONFLICT UPDATE).", "fontSize": 12, "fontFamily": 1, "strokeColor": "#495057"
    },

