    {
      "type": "text", "id": "flow3-note", "x": 30, "y": 720, "width": 800, "height": 70,
      "text": "Datos que fluyen Cloud→Local: productos, categorías, precios, configuración de menú.\nDatos que fluyen Local→Cloud: órdenes, pagos, movimientos de inventario.\nConflictos por dominio: Orders=append-only, Modifications=last-write-wins, Payments=idempotent TX ID, Inventory=delta-based.", "fontSize": 12, "fontFamily": 1, "strokeColor": "#495057"
    }
