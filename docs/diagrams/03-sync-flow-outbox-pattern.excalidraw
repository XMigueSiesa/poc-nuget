    {
      "type": "text", "id": "flow1-note", "x": 30, "y": 190, "width": 800, "height": 70,
      "text": "El POS recibe respuesta inmediata. La sincronización con la nube ocurre después, en background.\nSi no hay internet, la orden queda en sync_outbox hasta que se restaure la conexión.\nCada registro en sync_outbox tiene: id (ULID), entity_type, entity_id, payload (JSON), created_at, synced_at (null)", "fontSize": 12, "fontFamily": 1, "strokeColor": "#495057"
    },

